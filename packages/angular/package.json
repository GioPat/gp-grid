{
  "name": "@gp-grid/angular",
  "description": "A high-performance Angular data grid component with virtual scrolling, cell selection, sorting, filtering, and Excel-like editing",
  "version": "0.12.1",
  "license": "Apache-2.0",
  "module": "dist/angular/fesm2022/gp-grid-angular.mjs",
  "typings": "dist/angular/types/gp-grid-angular.d.ts",
  "exports": {
    "./package.json": {
      "default": "./package.json"
    },
    ".": {
      "types": "./dist/angular/types/gp-grid-angular.d.ts",
      "default": "./dist/angular/fesm2022/gp-grid-angular.mjs"
    },
    "./dist/styles.css": "./dist/styles.css"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GioPat/gp-grid.git",
    "directory": "packages/angular"
  },
  "bugs": {
    "url": "https://github.com/GioPat/gp-grid/issues"
  },
  "homepage": "https://github.com/GioPat/gp-grid/tree/master/packages/angular#readme",
  "keywords": [
    "angular",
    "grid",
    "data-grid",
    "datagrid",
    "angular-grid",
    "angular-table",
    "table",
    "data-table",
    "datatable",
    "virtual-scroll",
    "virtualization",
    "typescript",
    "high-performance",
    "spreadsheet",
    "excel",
    "lightweight",
    "cell-selection",
    "sorting",
    "filtering",
    "editable"
  ],
  "scripts": {
    "build": "ng-packagr -p ng-package.json",
    "postbuild": "node scripts/postbuild.mjs",
    "build:production": "ng-packagr -p ng-package.json",
    "postbuild:production": "node scripts/postbuild.mjs --strip-sourcemaps"
  },
  "peerDependencies": {
    "@angular/common": ">=18.0.0",
    "@angular/core": ">=18.0.0"
  },
  "devDependencies": {
    "@angular/common": "^18.0.0",
    "@angular/compiler": "^18.0.0",
    "@angular/compiler-cli": "^18.0.0",
    "@angular/core": "^18.0.0",
    "ng-packagr": "^18.0.0",
    "typescript": "~5.9.0"
  },
  "dependencies": {
    "@gp-grid/core": "workspace:*",
    "tslib": "^2.8.1"
  }
}
